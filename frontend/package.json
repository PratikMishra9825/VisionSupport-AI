    "react-dom": "19.2.4",
    "socket.io-client": "^4.8.3",
    "three": "^0.184.0",
    "uuid": "^14.0.0",
    "zustand": "^5.0.14",
    "mediasoup-client": "^3.7.16",
    "lucide-react": "^0.400.0"
  },
  "devDependencies": {
